# Telegram Bot Token — create a bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID — message @userinfobot to get it
TELEGRAM_CHAT_ID=your_chat_id_here

# Partner's email address (for weekly coordination emails)
PARTNER_EMAIL=partner@example.com

# AgentMail inbox for sending emails — sign up at https://agentmail.to
AGENTMAIL_API_KEY=your_agentmail_key_here
AGENTMAIL_FROM_EMAIL=familyos@agentmail.to

# Google Calendar integration (optional — uses gog CLI)
# https://github.com/yourusername/gog
PRIMARY_GOOGLE_ACCOUNT=you@gmail.com
PARTNER_GOOGLE_ACCOUNT=partner@gmail.com
PARTNER_CALENDAR_ID=partner@gmail.com

# Optional: write stats to a file (e.g. for a personal site)
# Leave blank to disable
STATS_OUTPUT_PATH=

# Optional: Supermemory for context-aware suggestions
# Sign up at https://supermemory.ai
SUPERMEMORY_API_KEY=
